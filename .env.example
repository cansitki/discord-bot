# Discord Bot — Environment Variables
# Copy to .env and fill in your values.

# ── Required ──────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# ── Claude Authentication (pick one) ─────────────────────────────────
# Option A: API key from https://console.anthropic.com/
# ANTHROPIC_API_KEY=

# Option B: OAuth login with Claude Pro/Max account.
# Run /claude-login in Discord — no env var needed.
# Uses the same OAuth flow as Claude Code (pi SDK).
ANTHROPIC_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────
# Path to SQLite database file (default: ./data/bot.db)
# On Railway, set to /data/bot.db (volume mount path) to persist across redeploys.
DATABASE_PATH=./data/bot.db

# Claude model to use for AI responses (default: claude-sonnet-4-20250514)
CLAUDE_MODEL=

# Prefix for text-based commands (default: !)
COMMAND_PREFIX=!

# Guild ID for instant slash-command sync during development.
# Leave blank for global sync (takes up to 1 hour to propagate).
# On Railway (production), leave blank so commands are available in all guilds.
DEV_GUILD_ID=

# ── Railway-specific ──────────────────────────────────────────────────
# Ensures write permissions on Railway volume mount (may be needed
# depending on container user configuration).
# RAILWAY_RUN_UID=0
